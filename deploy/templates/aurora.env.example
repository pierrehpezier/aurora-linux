# Aurora Linux runtime configuration template.
# Copy to /opt/aurora-linux/config/aurora.env and edit as needed.

# Required: Sigma Linux rules directory.
AURORA_RULES_DIR=/opt/aurora-linux/sigma-rules/rules/linux

# Required: local Aurora log file.
AURORA_LOG_FILE=/var/log/aurora-linux/aurora.log

# Output format flag.
# Use --json for SIEM ingestion, or leave empty for text mode.
AURORA_OUTPUT_FLAG=--json

# Optional extra CLI flags appended to aurora service startup.
# Example:
# AURORA_EXTRA_ARGS=--verbose --stats-interval 30 --throttle-rate 2 --throttle-burst 10
AURORA_EXTRA_ARGS=

# Optional update token for aurora-util GitHub API access.
# Uncomment if your hosts are API-rate-limited.
# GITHUB_TOKEN=ghp_xxx_replace_me

# Remote receiver integration notes:
# Aurora does not send directly to remote collectors today.
# Use a log shipper or syslog forwarder to stream AURORA_LOG_FILE.
# Example templates:
#   - /opt/aurora-linux/deploy/templates/rsyslog-aurora.conf.example
#   - /opt/aurora-linux/deploy/templates/aurora-maintenance.cron.example
