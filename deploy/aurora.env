# Aurora Linux package defaults.
# This file can be overridden per host without editing the systemd unit.

# Bundled Sigma Linux rules (keeps SigmaHQ repo structure: rules/linux).
AURORA_RULES_DIR=/opt/aurora-linux/sigma-rules/rules/linux

# Aurora output log path.
AURORA_LOG_FILE=/var/log/aurora-linux/aurora.log

# Output format flag: --json (SIEM-friendly) or empty for text output.
AURORA_OUTPUT_FLAG=--json

# Extra CLI flags appended to the aurora command line.
# Example: --verbose --stats-interval 30 --throttle-rate 2 --throttle-burst 10
AURORA_EXTRA_ARGS=
